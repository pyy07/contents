# Agent 环境变量配置模板
# 复制为 .env 后填入真实值，.env 已被 .gitignore 排除不会提交

# -----------------------------------------------------------------------------
# 通用 LLM 配置（未配置某 Agent 专属变量时作为回退）
# -----------------------------------------------------------------------------
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# 主 Agent（Orchestrator）专用
# -----------------------------------------------------------------------------
# LLM_MAIN_API_KEY=
# LLM_MAIN_BASE_URL=https://api.openai.com/v1
# LLM_MAIN_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Sub-Agent: info（信息获取）专用
# -----------------------------------------------------------------------------
# LLM_INFO_API_KEY=
# LLM_INFO_BASE_URL=https://api.openai.com/v1
# LLM_INFO_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# 后续新增 Sub-Agent 时按同样规则添加，如：
# LLM_<AGENT_ID>_API_KEY=
# LLM_<AGENT_ID>_BASE_URL=
# LLM_<AGENT_ID>_MODEL=
# agent_id 大写、中划线改为下划线，例如 other_agent -> LLM_OTHER_AGENT_*
# -----------------------------------------------------------------------------
